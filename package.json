{
  "name": "sentrygate",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/index.ts start",
    "build:linux": "bun build ./src/index.ts --compile --target=bun-linux-x64 --outfile sentrygate",
    "build:mac-arm": "bun build ./src/index.ts --compile --target=bun-darwin-arm64 --outfile sentrygate",
    "build:mac-intel": "bun build ./src/index.ts --compile --target=bun-darwin-x64 --outfile sentrygate",
    "build:windows": "bun build ./src/index.ts --compile --target=bun-windows-x64 --outfile sentrygate.exe",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
